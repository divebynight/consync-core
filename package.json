{
  "name": "consync-core",
  "main": ".vite/build/index.js",
  "private": true,
  "scripts": {
    "check:state-postflight": "node src/index.js state-integrity-check postflight",
    "check:state-preflight": "node src/index.js state-integrity-check preflight",
    "check:reentry": "node src/index.js reentry-check",
    "gatekeeper:mount": "node src/index.js gatekeeper mount",
    "gatekeeper:close": "node src/index.js gatekeeper close",
    "gatekeeper:switch": "node src/index.js gatekeeper switch",
    "check:handoff-contract": "node scripts/check-handoff-contract.js",
    "probe:audio-session": "cd sandbox/probes/audio-session-capture/workdir && node ../capture-session.js",
    "start:desktop": "electron-forge start",
    "package:desktop": "electron-forge package",
    "make:desktop": "electron-forge make",
    "test:ui-search": "vitest run --environment jsdom src/test/app-search-flow.test.jsx",
    "test:handoff-contract": "node src/test/handoff-contract-checker.js",
    "test:state-integrity-checks": "node src/test/state-integrity-checks.js",
    "test:gatekeeper": "node src/test/gatekeeper-checks.js",
    "test:probe:audio-session": "node sandbox/probes/audio-session-capture/test-capture-session.js",
    "test:desktop-scaffold": "node src/test/desktop-scaffold.js",
    "verify": "node src/test/verify.js",
    "test:unit": "node src/test/unit-new-guid.js",
    "test:integration": "node src/test/integration-new-guid-cli.js",
    "test": "npm run test:unit && npm run test:integration"
  },
  "version": "0.0.11",
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-vite": "^7.8.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.1.5",
    "jsdom": "^29.0.2",
    "vite": "^6.3.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
